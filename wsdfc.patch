+def _normalize_filters(filters: Optional[Dict[str, Any]]) -> Dict[str, Any]:
+    """Coerce a free-form brief-derived filter dict into typed numeric bounds.
+
+    Accepted keys (all optional): price_min, price_max, bedrooms_min,
+    bedrooms_max, bedrooms (exact → expands to min+max), extra_keywords
+    (List[str] | str, appended to Mudah q=).
+    Unknown keys are ignored. Invalid numerics are dropped silently rather
+    than raising — the caller's brief shape is not fully validated.
+    """
+    if not filters:
+        return {}
+    out: Dict[str, Any] = {}
+    for k in ("price_min", "price_max"):
+        v = filters.get(k)
+        try:
+            if v is not None:
+                fv = float(v)
+                if fv > 0:
+                    out[k] = fv
+        except (TypeError, ValueError):
+            pass
+    # `bedrooms` shorthand → exact match → s/e bedroom both = N
+    if filters.get("bedrooms") is not None and "bedrooms_min" not in filters and "bedrooms_max" not in filters:
+        try:
+            b = int(filters["bedrooms"])
+            if b > 0:
+                out["bedrooms_min"] = b
+                out["bedrooms_max"] = b
+        except (TypeError, ValueError):
+            pass
+    for k in ("bedrooms_min", "bedrooms_max"):
+        v = filters.get(k)
+        try:
+            if v is not None:
+                iv = int(v)
+                if iv > 0:
+                    out[k] = iv
+        except (TypeError, ValueError):
+            pass
+    kw = filters.get("extra_keywords")
+    if isinstance(kw, str):
+        kw = [kw]
+    if isinstance(kw, (list, tuple)):
+        cleaned = [str(x).strip() for x in kw if str(x).strip()]
+        if cleaned:
+            out["extra_keywords"] = cleaned
+    return out
+
