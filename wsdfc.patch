 // Defaults to fetch; ready to upgrade to SSE without changing call sites.
 // ============================================================================
 import type {
+  BackendProperty,
+  BackendRemark,
   ChatResponse,
   InitSessionResponse,
   NextBatchResponse,
   Phase1Form,
+  PropertyResult,
+  RawNextBatchResponse,
+  RawSearchStatusResponse,
+  ReasonDislikeResponse,
   RejectAllResponse,
   RejectSingleResponse,
   SearchStatusResponse,
   SessionReadyResponse,
 } from "./types";
 
+// ─────────────────────────────────────────────────────────────────────
+// Backend → frontend adapter
+// Backend returns Property objects with a nested `scraped_data` envelope
+// plus a parallel `remarks` array (Optional[PropertyRemark], aligned by
+// index after v4 C1). The UI consumes the flat PropertyResult shape, so
+// every transport that surfaces properties must run through this mapper.
+// ─────────────────────────────────────────────────────────────────────
+function mapBackendProperty(
+  p: BackendProperty,
+  r: BackendRemark | null | undefined,
+): PropertyResult {
+  const sd = p.scraped_data ?? ({} as BackendProperty["scraped_data"]);
+  return {
+    property_id: p.property_id,
+    title: sd.title ?? "Untitled",
+    price: typeof sd.price === "number" ? sd.price : 0,
+    location: sd.location_area ?? sd.city ?? sd.region ?? "",
+    feature_tags: p.feature_tags ?? [],
+    tier: r?.tier ?? "tier_1",
+    ai_remarks: r?.remarks,
+    missing_features: r?.missing_features,
+    remedy: r?.remedy ?? undefined,
+    image_url: sd.image_urls?.[0],
+    url: sd.listing_url,
+    is_mock: p.is_mock ?? false,
+  };
+}
+
+function mapSearchStatus(raw: RawSearchStatusResponse): SearchStatusResponse {
+  const results = raw.results?.map((p, i) =>
+    mapBackendProperty(p, raw.remarks?.[i]),
+  );
+  return {
+    status: raw.status,
+    batch_index: raw.batch_index,
+    total_available: raw.total_available,
+    has_more: raw.has_more,
+    tier3_triggered: raw.tier3_triggered,
+    degraded: raw.degraded,
+    results,
+  };
+}
+
+function mapNextBatch(raw: RawNextBatchResponse): NextBatchResponse {
+  return {
+    batch_index: raw.batch_index,
+    total_available: raw.total_available,
+    has_more: raw.has_more,
+    tier3_triggered: raw.tier3_triggered,
+    degraded: raw.degraded,
+    results: (raw.results ?? []).map((p, i) =>
+      mapBackendProperty(p, raw.remarks?.[i]),
+    ),
+  };
+}
