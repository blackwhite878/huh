@@ -69,6 +69,38 @@
 
 
 def validate_npp_tags(tags: list[str]) -> bool:
-    """Check if all tags are in the frozen NPP_ENUM."""
+    """Check if all tags are in the frozen NPP_ENUM.
+
+    Kept for backward compatibility. Prefer ``filter_npp_tags`` which is
+    permissive and is what the API layer uses on LLM-derived tags.
+    """
     return all(tag in NPP_ENUM for tag in tags)
 
+
+def filter_npp_tags(tags: list[str]) -> list[str]:
+    """Permissive validation for LLM-produced NPP tags.
+
+    Drops tags that are not in the frozen ``NPP_ENUM`` (logging each drop so
+    the prompt drift is visible in server logs) and returns the surviving
+    list. Order is preserved; duplicates collapsed. Empty / non-string entries
+    are silently dropped — they are never useful downstream.
+    """
+    import logging
+    log = logging.getLogger("npp_enum")
+    cleaned: list[str] = []
+    seen: set[str] = set()
+    for raw in tags or []:
+        if not isinstance(raw, str):
+            log.info("[npp] drop non-string tag: %r", raw)
+            continue
+        t = raw.strip()
+        if not t:
+            continue
+        if t in NPP_ENUM:
+            if t not in seen:
+                cleaned.append(t)
+                seen.add(t)
+        else:
+            log.warning("[npp] drop unknown tag: %r (not in NPP_ENUM)", t)
+    return cleaned
+
