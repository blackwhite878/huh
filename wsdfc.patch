diff --git a/backend/scoring_pipeline.py b/backend/scoring_pipeline.py
new file mode 100644
index 0000000..1234567
--- /dev/null
+++ b/backend/scoring_pipeline.py
@@ -0,0 +1,173 @@
+"""
+Scoring pipeline — compute property scores from scraped data fields.
+
+When ScrapedProperty has extended fields (distance_to_mrt_km,
+is_gated_guarded, etc.), compute exact scores. When those fields are
+absent (bare Mudah scrape), derive best-effort scores from description,
+raw_attributes, and facilities.
+"""
+import math
+import re
+from typing import Optional
+
+from schemas import Property, ScrapedProperty
+
+# Market reference values for normalization
+_REF_MAINTENANCE_FEE_SQFT = 0.50  # median MYR/sqft
+_MAX_MAINTENANCE_FEE_SQFT = 0.80  # cap for normalization
+_STANDARD_FACILITIES = {
+    "pool", "gym", "parking", "security", "playground",
+    "concierge", "barbecue", "jogging track", "sauna",
+}
+_MRT_WALKABLE_KM = 0.8
+_MRT_FAR_KM = 5.0
+
+
+def compute_price_fit_score(price: float, budget: float) -> float:
+    """Gaussian similarity around budget. 1.0 at budget, 0.5 at ±20%."""
+    if budget <= 0 or price <= 0:
+        return 0.0
+    diff_ratio = abs(price - budget) / budget
+    return math.exp(-(diff_ratio ** 2) / 0.18)
+
+
+def compute_security_score(is_gated: Optional[bool], security_level: Optional[str]) -> float:
+    """Score from gated status + security level."""
+    gated_bonus = 0.4 if is_gated else 0.0
+    level_map = {"high": 0.6, "medium": 0.35, "low": 0.1}
+    level_score = level_map.get((security_level or "").lower(), 0.0)
+    return min(1.0, gated_bonus + level_score)
+
+
+def compute_transit_score(distance_to_mrt_km: Optional[float]) -> float:
+    """Inverse distance to MRT. 1.0 at 0km, 0.0 at _MRT_FAR_KM."""
+    if distance_to_mrt_km is None:
+        return 0.0
+    if distance_to_mrt_km <= _MRT_WALKABLE_KM:
+        return 1.0
+    return max(0.0, 1.0 - (distance_to_mrt_km - _MRT_WALKABLE_KM) / (_MRT_FAR_KM - _MRT_WALKABLE_KM))
+
+
+def compute_lifestyle_score(
+    schools: Optional[int],
+    malls: Optional[int],
+    clinics: Optional[int],
+) -> float:
+    """Weighted amenity count. Normalized to [0, 1]."""
+    s = schools or 0
+    m = malls or 0
+    c = clinics or 0
+    raw = s * 0.25 + m * 0.40 + c * 0.15
+    return min(1.0, raw / 3.0)
+
+
+def compute_facilities_score(facilities: list[str]) -> float:
+    """Ratio of available facilities to standard set."""
+    if not facilities:
+        return 0.0
+    available = {f.lower().strip() for f in facilities}
+    overlap = available & _STANDARD_FACILITIES
+    return min(1.0, len(overlap) / max(1, len(_STANDARD_FACILITIES)))
+
+
+def compute_normalized_maintenance_fee(fee_per_sqft: Optional[float]) -> float:
+    """Normalize against market range. 0 = cheap, 1 = expensive."""
+    if fee_per_sqft is None:
+        return 0.0
+    return min(1.0, max(0.0, fee_per_sqft / _MAX_MAINTENANCE_FEE_SQFT))
+
+
+# NPP tag derivation from negative attributes
+_NEGATIVE_PATTERNS: list[tuple[re.Pattern, str]] = [
+    (re.compile(r"no\s+balcony|無陽台", re.I), "no_balcony"),
+    (re.compile(r"no\s+security|無保安|no guard", re.I), "no_security"),
+    (re.compile(r"no\s+pool|無泳池|no swimming", re.I), "no_pool"),
+    (re.compile(r"no\s+gym|無健身|no fitness", re.I), "no_gym"),
+    (re.compile(r"no\s+parking|無停車|no carpark", re.I), "no_parking"),
+    (re.compile(r"open\s+kitchen|開放式廚房", re.I), "open_kitchen"),
+    (re.compile(r"no\s+storage|無儲藏", re.I), "no_storage"),
+    (re.compile(r"small\s+unit|小戶型|studio", re.I), "small_unit"),
+    (re.compile(r"old\s+building|舊樓|老齡|樓齡", re.I), "old_building"),
+    (re.compile(r"high\s+maintenance|高管理費", re.I), "high_maintenance_fee"),
+    (re.compile(r"flood\s+risk|水患|淹水", re.I), "near_industrial"),
+    (re.compile(r"near\s+industrial|近工業", re.I), "near_industrial"),
+    (re.compile(r"noise|噪音|嘈雜", re.I), "noise_area"),
+    (re.compile(r"near\s+cemetery|近墓地", re.I), "near_cemetery"),
+]
+
+
+def derive_feature_tags(prop: Property) -> list[str]:
+    """Map negative attributes from scraped data to NPP_ENUM keys."""
+    tags: list[str] = list(prop.feature_tags)
+    sd = prop.scraped_data
+
+    # From floor level
+    fl = sd.floor_level
+    if fl is not None:
+        if fl >= 20:
+            tags.append("high_floor")
+        elif fl <= 3:
+            tags.append("low_floor")
+        if fl == 0:
+            tags.append("ground_floor")
+
+    # From facing
+    facing = (sd.facing or "").lower()
+    if facing == "west":
+        tags.append("west_facing")
+    elif facing == "east":
+        tags.append("east_facing")
+
+    # From MRT distance
+    if sd.distance_to_mrt_km is not None:
+        if sd.distance_to_mrt_km > 4.0:
+            tags.append("far_from_mrt")
+        if sd.distance_to_mrt_km > 6.0:
+            tags.append("far_from_bus")
+
+    # From security
+    if not sd.is_gated_guarded and (sd.security_level or "").lower() == "low":
+        tags.append("no_security")
+
+    # From facilities
+    fac_lower = {f.lower() for f in sd.facilities}
+    if "pool" not in fac_lower and sd.facilities:
+        tags.append("no_pool")
+    if "gym" not in fac_lower and sd.facilities:
+        tags.append("no_gym")
+    if "parking" not in fac_lower and "carpark" not in fac_lower and sd.facilities:
+        tags.append("no_parking")
+
+    # From description text
+    desc = (sd.description or "").lower()
+    for pat, tag in _NEGATIVE_PATTERNS:
+        if tag not in tags and pat.search(desc):
+            tags.append(tag)
+
+    # Deduplicate preserving order
+    seen: set[str] = set()
+    deduped: list[str] = []
+    for t in tags:
+        if t not in seen:
+            seen.add(t)
+            deduped.append(t)
+    return deduped
+
+
+def score_property(prop: Property, budget: float) -> Property:
+    """Orchestrator: populate all score fields from scraped data."""
+    sd = prop.scraped_data
+    price = sd.price or 0.0
+
+    prop.price_fit_score = compute_price_fit_score(price, budget)
+    prop.security_score = compute_security_score(sd.is_gated_guarded, sd.security_level)
+    prop.transit_proximity_score = compute_transit_score(sd.distance_to_mrt_km)
+    prop.lifestyle_proximity_score = compute_lifestyle_score(
+        sd.nearby_schools, sd.nearby_malls, sd.nearby_clinics,
+    )
+    prop.facilities_score = compute_facilities_score(sd.facilities)
+    prop.normalized_maintenance_fee = compute_normalized_maintenance_fee(
+        sd.maintenance_fee_per_sqft,
+    )
+    prop.feature_tags = derive_feature_tags(prop)
+    return prop

