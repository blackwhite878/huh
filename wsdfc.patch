@@ -0,0 +1,23 @@
+"""
+Serialization layer — convert Property (nested backend model) to
+PropertyResult (flat frontend contract). Returns plain dict so FastAPI
+serializes with the exact key names the frontend expects.
+"""
+from schemas import Property
+
+
+def property_to_result(prop: Property) -> dict:
+    sd = prop.scraped_data
+    return {
+        "property_id": prop.property_id,
+        "title": sd.title or "",
+        "price": sd.price or 0,
+        "location": sd.location_area or sd.city or "",
+        "feature_tags": prop.feature_tags,
+        "tier": prop.tier or "tier_1",
+        "ai_remarks": prop.ai_remarks,
+        "missing_features": prop.missing_features,
+        "remedy": prop.remedy,
+        "image_url": sd.image_urls[0] if sd.image_urls else None,
+        "url": sd.listing_url,
+    }

