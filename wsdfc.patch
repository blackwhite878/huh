+        existing_urls = {r["listing_url"] for r in load_longterm(region)}
+        new_rows = [
+            r for r in materialised
+            if r.get("listing_url") and r["listing_url"] not in existing_urls
+        ]
+        if not new_rows:
+            return 0
+        file_exists = p.exists()
+        with p.open("a", encoding="utf-8", newline="") as f:
+            w = csv.DictWriter(f, fieldnames=CSV_FIELDS, extrasaction="ignore")
+            if not file_exists:
+                w.writeheader()
+            for r in new_rows:
+                # normalise list → ';'-joined
+                if isinstance(r.get("image_urls"), list):
+                    r = {**r, "image_urls": ";".join(r["image_urls"])}
+                w.writerow(r)
+        return len(new_rows)
 
 
