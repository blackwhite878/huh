+def _row_matches_filters(row: Dict, filters: Dict[str, Any]) -> bool:
+    """Client-side enforcement of price/bedroom bounds.
+
+    Belt-and-braces against Mudah ignoring the URL filter params. Rows with
+    missing values are kept (None ≠ violation) to avoid silently dropping
+    everything when the detail parser can't extract a field.
+    """
+    if not filters:
+        return True
+    price = row.get("price")
+    if price is not None:
+        try:
+            p = float(price)
+            if "price_min" in filters and p < filters["price_min"]:
+                return False
+            if "price_max" in filters and p > filters["price_max"]:
+                return False
+        except (TypeError, ValueError):
+            pass
+    beds = row.get("bedrooms")
+    if beds is not None:
+        try:
+            b = int(beds)
+            if "bedrooms_min" in filters and b < filters["bedrooms_min"]:
+                return False
+            if "bedrooms_max" in filters and b > filters["bedrooms_max"]:
+                return False
+        except (TypeError, ValueError):
+            pass
+    return True
+
