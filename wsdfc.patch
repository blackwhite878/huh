diff --git a/backend/scraper/listing_validator.py b/backend/scraper/listing_validator.py
index 9774f99..eb48d31 100644
--- a/backend/scraper/listing_validator.py
+++ b/backend/scraper/listing_validator.py
@@ -45,7 +45,9 @@ def is_valid_price(price: Any, listing_type: str = "sale") -> bool:
         v = float(price)
     except (TypeError, ValueError):
         return False
-    lo, hi = (DEFAULT_RENT_RANGE if str(listing_type).lower().startswith("rent")
+    # Accept both short keys ("sale"/"rent") and the scraper's human strings
+    # ("For Sale"/"For Rent"); plain `startswith("rent")` would miss the latter.
+    lo, hi = (DEFAULT_RENT_RANGE if "rent" in str(listing_type).lower()
               else DEFAULT_SALE_RANGE)
     return lo <= v <= hi
 
@@ -54,7 +56,14 @@ def is_valid_row(row: dict) -> bool:
     """Convenience: apply both checks. Used as a filter() predicate."""
     if not is_valid_title(row.get("title")):
         return False
-    listing_type = row.get("listing_type") or row.get("property_action") or "sale"
+    # mudah_scraper._parse_detail emits `transaction_type` ("For Sale"/"For Rent");
+    # legacy/hack-repo rows may instead carry `listing_type` or `property_action`.
+    listing_type = (
+        row.get("listing_type")
+        or row.get("property_action")
+        or row.get("transaction_type")
+        or "sale"
+    )
     return is_valid_price(row.get("price"), listing_type)
 
 
