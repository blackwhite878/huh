+  18%  { transform: translate(6px, -8px)   rotate(22deg)   scale(1.45); opacity: 1;    }
+  37%  { transform: translate(-7px, -4px)  rotate(-18deg)  scale(0.8);  opacity: 0.9;  }
+  55%  { transform: translate(5px, 7px)    rotate(14deg)   scale(1.35); opacity: 1;    }
+  74%  { transform: translate(-6px, 5px)   rotate(-12deg)  scale(0.9);  opacity: 0.8;  }
+  100% { transform: translate(0, 0)        rotate(0deg)    scale(1);    opacity: 0.55; }
+}
+.wiggle-dot {
